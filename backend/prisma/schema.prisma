generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////////
//////////////////// ENUMS //////////////////////////////////
////////////////////////////////////////////////////////////

enum ProductType {
  INVENTORY
  PRODUCTION
}

////////////////////////////////////////////////////////////
//////////////////// SUPPLIERS //////////////////////////////
////////////////////////////////////////////////////////////

model Supplier {
  id    String  @id @default(uuid()) @db.Uuid
  name  String
  cnpj  String?
  phone String?
  email String?

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  createdAt        DateTime            @default(now())
  orderItems       PurchaseOrderItem[]
  productSuppliers ProductSupplier[]

  priceHistory   SupplierPriceHistory[]
  stockMovements StockMovement[]
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  products Product[]

  @@unique([name, establishmentId])
  @@map("categories")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  unit      String
  unitPrice Decimal? @db.Decimal(12, 2)

  quantity    Decimal @default(0) @db.Decimal(12, 3)
  minQuantity Decimal @default(0) @db.Decimal(12, 3)

  type ProductType @default(INVENTORY)

  purchaseUnit String?
  packQuantity Float?   @default(1)

  currentCost Decimal? @db.Decimal(12, 2)

  isActive Boolean @default(true)

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  categoryId String   @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  auditItems            StockAuditItem[]
  orderItems            PurchaseOrderItem[]
  stockMovements        StockMovement[]
  productSuppliers      ProductSupplier[]
  supplierPriceHistory  SupplierPriceHistory[]
  recipeItems           RecipeItem[]
  Recipe                Recipe?
  transfers             StockTransfer[]
  consumptionEventItems ConsumptionEventItem[]

  @@map("products")
}

model PurchaseOrder {
  id          String    @id @default(uuid()) @db.Uuid
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user_id String @db.Uuid
  users   users  @relation(fields: [user_id], references: [id])

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  items PurchaseOrderItem[]

  @@index([establishmentId])
  @@index([createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @db.Uuid
  productId       String? @db.Uuid
  supplierId      String? @db.Uuid

  productName      String
  adjustedQuantity Decimal @db.Decimal(12, 3)
  unitPrice        Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product?      @relation(fields: [productId], references: [id])
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])

  @@map("purchase_order_items")
}

model StockMovement {
  id String @id @default(uuid()) @db.Uuid

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id])

  productName String
  type        String

  quantity         Decimal @db.Decimal(12, 3)
  previousQuantity Decimal @db.Decimal(12, 3)
  newQuantity      Decimal @db.Decimal(12, 3)

  reference String
  reason    String?
  createdAt DateTime       @default(now())
  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])
  unitCost  Decimal? @db.Decimal(12, 2)
  totalCost Decimal? @db.Decimal(14, 2)
  supplierId String? @db.Uuid
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  @@index([establishmentId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  actionType  String
  entityType  String
  entityId    String
  description String

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  createdAt DateTime @default(now())

  @@index([establishmentId])
  @@index([createdAt])
  @@map("audit_logs")
}

model establishments {
  id            String  @id @default(uuid()) @db.Uuid
  name          String
  cnpj          String?
  telefone      String?
  endereco      String?
  cidade        String?
  estado        String?

  users              UserEstablishment[]
  products           Product[]
  suppliers          Supplier[]
  categories         Category[]
  auditLogs          AuditLog[]
  recipes            Recipe[]
  stockAudits        StockAudit[]
  organizationId     String?
  organization       Organization?       @relation(fields: [organizationId], references: [id])

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  transfersFrom      StockTransfer[]     @relation("TransferFrom")
  transfersTo        StockTransfer[]     @relation("TransferTo")
  stockMovements     StockMovement[]
  purchaseOrders     PurchaseOrder[]
  consumptionEvents  ConsumptionEvent[]
}

model users {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  establishments  UserEstablishment[]
  stockAudits     StockAudit[]
  purchase_orders PurchaseOrder[]
}

model ProductSupplier {
  id String @id @default(uuid()) @db.Uuid

  productId  String @db.Uuid
  supplierId String @db.Uuid

  price Decimal @default(0) @db.Decimal(12, 2)

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  createdAt DateTime @default(now())

  @@unique([productId, supplierId])
  @@map("product_suppliers")
}

model SupplierPriceHistory {
  id String @id @default(uuid()) @db.Uuid

  productId  String @db.Uuid
  supplierId String @db.Uuid

  price Decimal @db.Decimal(12, 2)

  purchaseOrderId String? @db.Uuid

  createdAt DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([productId])
  @@index([supplierId])
  @@map("supplier_price_history")
}

model Recipe {
  id String @id @default(uuid()) @db.Uuid

  productId String  @unique @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  items RecipeItem[]

  createdAt DateTime @default(now())

  @@map("recipes")
}

model RecipeItem {
  id String @id @default(uuid()) @db.Uuid

  recipeId String @db.Uuid
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())

  @@unique([recipeId, productId])
  @@map("recipe_items")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  establishments establishments[]
}

model StockTransfer {
  id String @id @default(uuid()) @db.Uuid

  productId String @db.Uuid
  quantity  Float

  fromEstablishmentId String @db.Uuid
  toEstablishmentId   String @db.Uuid

  status TransferStatus @default(PENDING)

  createdBy  String  @db.Uuid
  approvedBy String? @db.Uuid

  createdAt  DateTime  @default(now())
  approvedAt DateTime?

  product Product @relation(fields: [productId], references: [id])

  fromEstablishment establishments @relation("TransferFrom", fields: [fromEstablishmentId], references: [id])
  toEstablishment   establishments @relation("TransferTo", fields: [toEstablishmentId], references: [id])
}

model UserEstablishment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  establishmentId String   @db.Uuid

  role            String   // ex: ADMIN, MANAGER, STAFF
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  user           users          @relation(fields: [userId], references: [id])
  establishment  establishments @relation(fields: [establishmentId], references: [id])

  @@unique([userId, establishmentId])
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

model StockAudit {
  id String @id @default(uuid()) @db.Uuid

  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])

  createdBy String @db.Uuid
  user      users  @relation(fields: [createdBy], references: [id])

  status String @default("OPEN")

  createdAt DateTime @default(now())

  items StockAuditItem[]

  @@index([establishmentId])
  @@index([createdAt])
  @@index([createdBy])
  @@map("stock_audits")
}

model StockAuditItem {
  id String @id @default(uuid()) @db.Uuid

  auditId String     @db.Uuid
  audit   StockAudit @relation(fields: [auditId], references: [id])

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  systemQuantity  Decimal @db.Decimal(12, 3)

  countedQuantity Decimal @default(0) @db.Decimal(12, 3)

  difference Decimal @default(0) @db.Decimal(12, 3)

  @@map("stock_audit_items")
}

model ConsumptionEvent {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  status          String         @default("OPEN") // OPEN, CLOSED
  establishmentId String         @db.Uuid
  establishment   establishments @relation(fields: [establishmentId], references: [id])
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  items           ConsumptionEventItem[]

  @@index([establishmentId])
  @@map("consumption_events")
}

model ConsumptionEventItem {
  id              String    @id @default(uuid()) @db.Uuid
  eventId         String    @db.Uuid
  event           ConsumptionEvent @relation(fields: [eventId], references: [id])
  productId       String    @db.Uuid
  product         Product   @relation(fields: [productId], references: [id])
  withdrawnQty    Decimal   @db.Decimal(12, 3) // em unidades base (ml/g)
  returnedQty     Decimal   @default(0) @db.Decimal(12, 3) // em unidades base (ml/g)
  unitCost        Decimal   @db.Decimal(12, 2) // custo unitário no momento da retirada

  createdAt       DateTime  @default(now())

  @@index([eventId])
  @@index([productId])
  @@map("consumption_event_items")
}



