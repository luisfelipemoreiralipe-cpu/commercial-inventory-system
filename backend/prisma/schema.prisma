generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:12345@localhost:5432/commercial_db"
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  cnpj      String    @unique
  phone     String?
  email     String?
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("suppliers")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id             String              @id @default(uuid())
  name           String
  unit           String
  unitPrice      Decimal             @db.Decimal(12, 2)
  quantity       Int                 @default(0)
  minQuantity    Int                 @default(0)
  supplierId     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  categoryId     String
  category       Category            @relation(fields: [categoryId], references: [id])
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  orderItems     PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@map("products")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  status      String              @default("pending")
  createdAt   DateTime            @default(now())
  completedAt DateTime?
  user_id     String              @db.Uuid
  items       PurchaseOrderItem[]
  users       users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_order")

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  productId        String?
  productName      String
  adjustedQuantity Int
  unitPrice        Decimal       @db.Decimal(12, 2)
  product          Product?      @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model StockMovement {
  id               String   @id @default(uuid())
  productId        String?
  productName      String
  type             String
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reference        String
  createdAt        DateTime @default(now())
  product          Product? @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}

model AuditLog {
  id          String   @id @default(uuid())
  actionType  String
  entityType  String
  entityId    String
  description String
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model establishment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @unique @db.Uuid
  nome_fantasia String    @db.VarChar(150)
  cnpj          String?   @db.VarChar(20)
  telefone      String?   @db.VarChar(20)
  endereco      String?   @db.VarChar(255)
  cidade        String?   @db.VarChar(100)
  estado        String?   @db.VarChar(2)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
}

model users {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome            String          @db.VarChar(150)
  email           String          @unique @db.VarChar(150)
  senha_hash      String
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  updated_at      DateTime?       @default(now()) @db.Timestamp(6)
  establishment   establishment?
  purchase_orders PurchaseOrder[]
}
