generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////////
//////////////////// ENUMS //////////////////////////////////
////////////////////////////////////////////////////////////

enum ProductType {
  INVENTORY
  RECIPE
}

////////////////////////////////////////////////////////////
//////////////////// SUPPLIERS //////////////////////////////
////////////////////////////////////////////////////////////

model Supplier {
  id    String  @id @default(uuid()) @db.Uuid
  name  String
  cnpj  String?
  phone String?
  email String?

  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id])

  createdAt        DateTime            @default(now())
  orderItems       PurchaseOrderItem[]
  productSuppliers ProductSupplier[]

  priceHistory SupplierPriceHistory[]
}

////////////////////////////////////////////////////////////
//////////////////// CATEGORIES /////////////////////////////
////////////////////////////////////////////////////////////

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())

  establishmentId String?        @db.Uuid
  establishment   Establishment? @relation(fields: [establishmentId], references: [id])

  products Product[]

  @@map("categories")
}

////////////////////////////////////////////////////////////
//////////////////// PRODUCTS ///////////////////////////////
////////////////////////////////////////////////////////////

model Product {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  unit      String
  unitPrice Decimal? @db.Decimal(12, 2)

  quantity    Int @default(0)
  minQuantity Int @default(0)

  type ProductType @default(INVENTORY)

  // Soft delete
  isActive Boolean @default(true)

  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id])

  categoryId String @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relações
  orderItems       PurchaseOrderItem[]
  stockMovements   StockMovement[]
  productSuppliers ProductSupplier[]

  supplierPriceHistory SupplierPriceHistory[]
  recipeItems          RecipeItem[]
  Recipe               Recipe?

  @@map("products")
}

////////////////////////////////////////////////////////////
//////////////////// PURCHASE ORDERS ////////////////////////
////////////////////////////////////////////////////////////

model PurchaseOrder {
  id          String    @id @default(uuid()) @db.Uuid
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user_id String @db.Uuid
  users   users  @relation(fields: [user_id], references: [id])

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @db.Uuid
  productId       String? @db.Uuid
  supplierId      String? @db.Uuid

  productName      String
  adjustedQuantity Decimal @db.Decimal(12, 3)
  unitPrice        Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product?      @relation(fields: [productId], references: [id])
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])

  @@map("purchase_order_items")
}

////////////////////////////////////////////////////////////
//////////////////// STOCK MOVEMENTS ////////////////////////
////////////////////////////////////////////////////////////

model StockMovement {
  id String @id @default(uuid()) @db.Uuid

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id])

  productName String
  type        String

  quantity         Decimal @db.Decimal(12, 3)
  previousQuantity Decimal @db.Decimal(12, 3)
  newQuantity      Decimal @db.Decimal(12, 3)

  reference String

  createdAt DateTime @default(now())

  @@map("stock_movements")
}

////////////////////////////////////////////////////////////
//////////////////// AUDIT LOG //////////////////////////////
////////////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  actionType  String
  entityType  String
  entityId    String
  description String

  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

////////////////////////////////////////////////////////////
//////////////////// ESTABLISHMENT //////////////////////////
////////////////////////////////////////////////////////////

model Establishment {
  id String @id @default(uuid()) @db.Uuid

  user_id String @unique @db.Uuid

  nome_fantasia String
  cnpj          String?
  telefone      String?
  endereco      String?
  cidade        String?
  estado        String?

  users users @relation(fields: [user_id], references: [id])

  products   Product[]
  categories Category[]
  suppliers  Supplier[]
  auditLogs  AuditLog[]
  recipes    Recipe[]
}

////////////////////////////////////////////////////////////
//////////////////// USERS //////////////////////////////////
////////////////////////////////////////////////////////////

model users {
  id         String @id @default(uuid()) @db.Uuid
  nome       String
  email      String @unique
  senha_hash String

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  establishment   Establishment?
  purchase_orders PurchaseOrder[]
}

////////////////////////////////////////////////////////////
//////////////////// PRODUCT SUPPLIERS //////////////////////
////////////////////////////////////////////////////////////

model ProductSupplier {
  id String @id @default(uuid()) @db.Uuid

  productId  String @db.Uuid
  supplierId String @db.Uuid

  price Decimal @default(0) @db.Decimal(12, 2)

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  createdAt DateTime @default(now())

  @@unique([productId, supplierId])
  @@map("product_suppliers")
}

////////////////////////////////////////////////////////////
//////////////////// PRICE HISTORY //////////////////////////
////////////////////////////////////////////////////////////

model SupplierPriceHistory {
  id String @id @default(uuid()) @db.Uuid

  productId  String @db.Uuid
  supplierId String @db.Uuid

  price Decimal @db.Decimal(12, 2)

  purchaseOrderId String? @db.Uuid

  createdAt DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([productId])
  @@index([supplierId])
  @@map("supplier_price_history")
}

////////////////////////////////////////////////////////////
//////////////////// RECIPES ////////////////////////////////
////////////////////////////////////////////////////////////

model Recipe {
  id String @id @default(uuid()) @db.Uuid

  productId String  @unique @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id])

  items RecipeItem[]

  createdAt DateTime @default(now())

  @@map("recipes")
}

model RecipeItem {
  id String @id @default(uuid()) @db.Uuid

  recipeId String @db.Uuid
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())

  @@unique([recipeId, productId])
  @@map("recipe_items")
}
