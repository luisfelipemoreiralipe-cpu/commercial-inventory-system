{
    "name": "controle-de-compras-bds-backend",
    "version": "1.0.0",
    "description": "Internal Inventory Management System — REST API",
    "main": "src/server.js",
    "scripts": {
        "dev": "nodemon src/server.js",
        "build": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed",
        "start": "node src/server.js",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "clone-branch": "node scripts/cloneBranch.js"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "csv-parser": "^3.2.0",
        "dotenv": "^16.4.5",
        "dotenv-cli": "^11.0.0",
        "express": "^4.18.3",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.1",
        "pdfkit": "^0.17.2",
        "react-hot-toast": "^2.6.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "nodemon": "^3.1.14",
        "prisma": "^5.22.0"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}