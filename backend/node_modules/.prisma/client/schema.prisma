// This is your Prisma schema file.
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:12345@localhost:5432/commercial_db"
}

// ─── Supplier ─────────────────────────────────────────────────────────────────
model Supplier {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  phone     String?
  email     String?
  createdAt DateTime @default(now())

  products Product[]

  @@map("suppliers")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())

  @@map("categories")
}

// ─── Product ──────────────────────────────────────────────────────────────────
model Product {
  id          String   @id @default(uuid())
  name        String
  categoryId  String
  unit        String
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(0)
  minQuantity Int      @default(0)
  supplierId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier       Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  category       Category            @relation(fields: [categoryId], references: [id])
  stockMovements StockMovement[]
  orderItems     PurchaseOrderItem[]

  @@map("products")
}

// ─── Purchase Order ───────────────────────────────────────────────────────────
model PurchaseOrder {
  id          String    @id @default(uuid())
  status      String    @default("pending") // "pending" | "completed"
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

// ─── Purchase Order Item ──────────────────────────────────────────────────────
model PurchaseOrderItem {
  id               String  @id @default(uuid())
  purchaseOrderId  String
  productId        String?
  productName      String // snapshot — preserved even if product is deleted
  adjustedQuantity Int
  unitPrice        Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("purchase_order_items")
}

// ─── Stock Movement ───────────────────────────────────────────────────────────
model StockMovement {
  id               String   @id @default(uuid())
  productId        String?
  productName      String // snapshot
  type             String // "entry" | "exit" | "adjustment"
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reference        String
  createdAt        DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  actionType  String // "CREATE" | "UPDATE" | "DELETE" | "COMPLETE"
  entityType  String // "PRODUCT" | "SUPPLIER" | "PURCHASE_ORDER"
  entityId    String
  description String
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}
